            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('TotalElements is 2 (MWH.001 archived)', () => pm.expect(json.totalElements).to.eql(2));",
              "const codes = json.data.map(w => w.businessUnitCode);",
              "pm.test('MWH.001 not in results', () => pm.expect(codes).to.not.include('MWH.001'));",
              "pm.test('MWH.012 still present', () => pm.expect(codes).to.include('MWH.012'));",
              "pm.test('MWH.023 still present', () => pm.expect(codes).to.include('MWH.023'));"
