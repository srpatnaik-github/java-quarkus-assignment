    {
      "name": "UC-1: Get All Active Warehouses (No Filters)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('Has 3 active warehouses', () => pm.expect(json.data.length).to.eql(3));",
              "pm.test('Page is 0', () => pm.expect(json.page).to.eql(0));",
              "pm.test('PageSize is 10', () => pm.expect(json.pageSize).to.eql(10));",
              "pm.test('TotalElements is 3', () => pm.expect(json.totalElements).to.eql(3));",
              "pm.test('TotalPages is 1', () => pm.expect(json.totalPages).to.eql(1));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/warehouse/search",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "warehouse",
            "search"
          ]
        }
      },
      "response": []
    },
